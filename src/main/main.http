# LifeInsuranceCRM.API — local requests
# Standalone: dotnet run --project main/LifeInsuranceCRM.API.csproj (http profile → port 5069)
# Aspire: use the API endpoint URL from the Aspire dashboard (port varies)

@main_HostAddress = http://localhost:5069

### Health — readiness
GET {{main_HostAddress}}/health
Accept: application/json

### Health — liveness
GET {{main_HostAddress}}/alive
Accept: application/json

### Status — anonymous
GET {{main_HostAddress}}/api/status
Accept: application/json

### Status — authenticated
GET {{main_HostAddress}}/api/status/authenticated
Accept: application/json

### List clients
GET {{main_HostAddress}}/api/clients?page=1&pageSize=25
Accept: application/json

### Search clients
GET {{main_HostAddress}}/api/clients?search=Jane&isActive=true
Accept: application/json

### Get client
GET {{main_HostAddress}}/api/clients/33333333-3333-3333-3333-333333333333
Accept: application/json

### Get client detail (profile shell)
GET {{main_HostAddress}}/api/clients/33333333-3333-3333-3333-333333333333/detail
Accept: application/json

### Create client
POST {{main_HostAddress}}/api/clients
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Doe",
  "isActive": true
}

### Update client
PUT {{main_HostAddress}}/api/clients/33333333-3333-3333-3333-333333333333
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Smith",
  "isActive": true,
  "isAcaClient": false,
  "hasContactConsent": true
}

### Patch client status
PATCH {{main_HostAddress}}/api/clients/33333333-3333-3333-3333-333333333333
Content-Type: application/json

{
  "isActive": false
}

### List interactions
GET {{main_HostAddress}}/api/clients/33333333-3333-3333-3333-333333333333/interactions
Accept: application/json

### List follow-ups
GET {{main_HostAddress}}/api/follow-ups
Accept: application/json

### OpenAPI document (Development only)
GET {{main_HostAddress}}/openapi/v1.json
Accept: application/json
